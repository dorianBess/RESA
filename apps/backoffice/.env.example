# URL du backend — remplace localhost par l'IP de la machine qui fait tourner le backend
# Exemple réseau local : http://192.168.1.42:3001/api/v1
# Exemple en local     : http://localhost:3001/api/v1
VITE_API_BASE_URL=http://localhost:3001/api/v1

