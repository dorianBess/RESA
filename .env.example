# Application
NODE_ENV=development
PORT=3000

# Base de données PostgreSQL
DATABASE_URL=postgresql://resa:resa@localhost:5432/resa_dev
DATABASE_SSL=false

# JWT
JWT_SECRET=change-this-secret-in-production
JWT_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# AWS SES (emails transactionnels)
AWS_REGION=eu-west-3
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
SES_FROM_EMAIL=noreply@resa.fr

# AWS S3 (stockage fichiers)
AWS_S3_BUCKET=resa-dev
AWS_CLOUDFRONT_URL=https://cdn.resa.fr

# Worker iCal
ICAL_SYNC_INTERVAL_MINUTES=15

# Admin RESA
ADMIN_INITIAL_EMAIL=admin@resa.fr
ADMIN_INITIAL_PASSWORD=change-in-production
